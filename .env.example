# Excel 导入导出服务地址（ExcelEditor 默认读取）
IMS_EXCHANGE_ENDPOINT=http://localhost:3010

# 若未设置 IMS_EXCHANGE_ENDPOINT，则用端口拼本地地址
IMS_SERVER_PORT=3010

# 大文件分块阈值（字节，默认 2MB）；超过则 LuckyExcel 解析后按行切块挂载
# IMS_EXCEL_CHUNK_BYTES=2097152

# 每块行数（默认 5000，仅影响渐进挂载切片，不是总行上限）
# IMS_EXCEL_BLOCK_ROWS=5000

# 全量导入行上限（默认 150000；设为 0 表示不截断）
# IMS_EXCEL_MAX_ROWS=150000

# 单次解析超时（毫秒，默认 10 分钟）
# IMS_EXCEL_PARSE_TIMEOUT_MS=600000

# 上传目录 / TTL（可选）
# IMS_EXCEL_UPLOAD_DIR=
# IMS_EXCEL_UPLOAD_TTL_MS=3600000
