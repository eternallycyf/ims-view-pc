{
  "name": "@ims-view/server",
  "version": "1.2.1",
  "description": "NestJS Excel import/export service for ExcelEditor (xlsx ↔ IWorkbookData)",
  "license": "MIT",
  "author": "eternallycyf(969475322@qq.com)",
  "homepage": "https://github.com/eternallycyf/ims-view-pc#readme",
  "bugs": {
    "url": "https://github.com/eternallycyf/ims-view-pc/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eternallycyf/ims-view-pc.git",
    "directory": "packages/server"
  },
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "bin": {
    "ims-view-server": "./bin/ims-view-server.js"
  },
  "files": [
    "lib",
    "bin",
    "README.md"
  ],
  "scripts": {
    "start": "node scripts/dev.cjs",
    "start:dev": "node scripts/dev.cjs",
    "start:once": "node scripts/dev.cjs --once",
    "start:debug": "node scripts/dev.cjs --inspect-brk",
    "build": "nest build",
    "clean": "rm -rf lib dist",
    "doctor": "node -e \"require('fs').accessSync('src/index.ts'); console.log('[@ims-view/server] doctor ok')\"",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@ims-view/univer-import-excel": "0.1.0",
    "@ims-view/utils": "1.22.1",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "compression": "^1.8.1",
    "exceljs": "^4.4.0",
    "multer": "^1.4.5-lts.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "typescript": "^5.4.5"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "nestjs",
    "excel",
    "xlsx",
    "univer",
    "ims-view"
  ]
}
